# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/smart_banking?retryWrites=true&w=majority

# Secret used to sign JWT auth tokens — use a long random string in production
JWT_SECRET=replace_this_with_a_long_random_secret

# Port the Express server listens on (Render sets this automatically)
PORT=5000

# Comma-separated list of allowed frontend origins (your Vercel URL)
CLIENT_ORIGIN=http://localhost:5173,https://your-app.vercel.app
